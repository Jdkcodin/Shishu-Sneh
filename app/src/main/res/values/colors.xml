<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml — App Color Palette

    Our color scheme is "soft & mother-friendly":
    - Soft pinks and roses for warmth and care
    - White cards for clean readability
    - Gentle lavender and peach as accents

    Naming convention:
    - primary_*   = main brand colors (rose)
    - secondary_* = supporting colors (lavender)
    - tertiary_*  = accent colors (peach)
    - text_*      = text colors
    - background_* = background colors
    - bmi_*       = BMI indicator colors (Phase 2)
    - chart_*     = Growth chart colors (Phase 2)
    - growth_*    = Growth summary colors (Phase 2)
-->
<resources>

    <!-- ===== PRIMARY COLORS (Rose — symbolizes love & care) ===== -->
    <color name="primary_rose">#E91E63</color>
    <color name="primary_rose_light">#FCE4EC</color>
    <color name="primary_rose_dark">#AD1457</color>

    <!-- ===== SECONDARY COLORS (Lavender — calming & gentle) ===== -->
    <color name="secondary_lavender">#CE93D8</color>
    <color name="secondary_lavender_light">#F3E5F5</color>

    <!-- ===== TERTIARY COLORS (Peach — warmth & comfort) ===== -->
    <color name="tertiary_peach">#FFAB91</color>
    <color name="tertiary_peach_light">#FBE9E7</color>

    <!-- ===== BACKGROUND COLORS ===== -->
    <color name="background_soft_pink">#FFF0F3</color>
    <color name="card_white">#FFFBFE</color>

    <!-- ===== TEXT COLORS ===== -->
    <color name="text_primary">#1C1B1F</color>
    <color name="text_secondary">#625B71</color>
    <color name="text_hint">#9E9E9E</color>

    <!-- ===== STATUS BAR ===== -->
    <color name="status_bar">#C2185B</color>

    <!-- ===== ICON TINT ===== -->
    <color name="icon_rose">#E91E63</color>

    <!-- ===== LAUNCHER ICON BACKGROUND ===== -->
    <color name="ic_launcher_background">#FCE4EC</color>

    <!-- ===== BMI INDICATOR COLORS (Phase 2) ===== -->
    <!-- Orange = Underweight, Green = Normal, Red = Overweight -->
    <color name="bmi_underweight">#FFA726</color>
    <color name="bmi_normal">#66BB6A</color>
    <color name="bmi_overweight">#EF5350</color>
    <color name="bmi_underweight_bg">#1AFFA726</color>
    <color name="bmi_normal_bg">#1A66BB6A</color>
    <color name="bmi_overweight_bg">#1AEF5350</color>

    <!-- ===== CHART COLORS (Phase 2) ===== -->
    <color name="chart_weight_line">#E91E63</color>
    <color name="chart_weight_fill">#33E91E63</color>
    <color name="chart_height_line">#CE93D8</color>
    <color name="chart_height_fill">#33CE93D8</color>
    <color name="chart_grid">#E0E0E0</color>
    <color name="chart_label">#757575</color>

    <!-- ===== GROWTH SUMMARY COLORS (Phase 2) ===== -->
    <color name="growth_positive">#4CAF50</color>
    <color name="growth_negative">#F44336</color>
    <color name="growth_neutral">#9E9E9E</color>
    <color name="growth_positive_bg">#1A4CAF50</color>
    <color name="growth_negative_bg">#1AF44336</color>

    <!-- ===== SWIPE DELETE (Phase 2) ===== -->
    <color name="swipe_delete_bg">#FFEBEE</color>
    <color name="swipe_delete_icon">#EF5350</color>

    <!-- ===== FAB COLORS ===== -->
    <color name="fab_background">#E91E63</color>
    <color name="fab_icon">#FFFFFF</color>

    <!-- ===== VACCINE STATUS COLORS (Phase 3) ===== -->
    <!-- Each status has a solid color + 10% transparent background -->
    <color name="vaccine_given">#66BB6A</color>           <!-- Green — administered -->
    <color name="vaccine_due">#FFA726</color>              <!-- Orange — due within 7 days -->
    <color name="vaccine_overdue">#EF5350</color>          <!-- Red — past due date -->
    <color name="vaccine_upcoming">#42A5F5</color>         <!-- Blue — scheduled for future -->
    <color name="vaccine_given_bg">#1A66BB6A</color>
    <color name="vaccine_due_bg">#1AFFA726</color>
    <color name="vaccine_overdue_bg">#1AEF5350</color>
    <color name="vaccine_upcoming_bg">#1A42A5F5</color>
    <color name="vaccine_progress">#CE93D8</color>         <!-- Lavender progress bar -->
    <color name="vaccine_progress_bg">#F3E5F5</color>      <!-- Light lavender track -->
    <color name="vaccine_section_bg">#FFF0F3</color>       <!-- Section header background -->

</resources>
