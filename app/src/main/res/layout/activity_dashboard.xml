<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_dashboard.xml — Main Dashboard Screen (Phase 2)

    Replaces the Phase 1 placeholder activity_main.xml.
    Shows: Profile card, Latest measurement + BMI, Growth summary,
    Mini growth chart, Action buttons, and a FAB for adding measurements.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft_pink">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ===== TOOLBAR ===== -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:title="@string/app_name"
                app:titleTextColor="@color/primary_rose_dark"
                app:menu="@menu/menu_dashboard"
                android:background="@android:color/transparent" />

            <!-- ===== PROFILE CARD (SWITCHER) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- Baby icon -->
                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_baby"
                        android:contentDescription="@string/welcome_icon_desc" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <!-- Baby name + Dashboard title -->
                        <TextView
                            android:id="@+id/textBabyName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_rose" />

                        <!-- Age + DOB -->
                        <TextView
                            android:id="@+id/textBabyAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Dropdown Arrow for Switcher -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_growth_down"
                        app:tint="@color/text_hint"
                        android:contentDescription="@string/cd_switch_profile" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== LATEST MEASUREMENT CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLatestMeasurement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_latest_measurement"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:drawableStart="@drawable/ic_chart"
                        android:drawablePadding="8dp" />

                    <!-- Empty state (shown when no measurements) -->
                    <TextView
                        android:id="@+id/textNoMeasurements"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_no_measurements"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone" />

                    <!-- Measurement values (shown when data exists) -->
                    <LinearLayout
                        android:id="@+id/layoutMeasurementValues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Weight / Height / Head row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <!-- Weight -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_weight"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_hint" />

                                <TextView
                                    android:id="@+id/textWeight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary_rose" />
                            </LinearLayout>

                            <!-- Height -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_height"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_hint" />

                                <TextView
                                    android:id="@+id/textHeight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/secondary_lavender" />
                            </LinearLayout>

                            <!-- Head Circumference -->
                            <LinearLayout
                                android:id="@+id/layoutHeadValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_head_circ"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_hint" />

                                <TextView
                                    android:id="@+id/textHeadCirc"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/tertiary_peach" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- BMI Row -->
                        <LinearLayout
                            android:id="@+id/layoutBmi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp"
                            
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_bmi"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/textBmiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textBmiCategory"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingStart="8dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <!-- Recorded date -->
                        <TextView
                            android:id="@+id/textRecordedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== GROWTH TREND (MINI CHART) CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrowthTrend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_white"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_growth_trend"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Mini LineChart -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/miniChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="12dp" />

                    <!-- View Full Chart button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonViewFullChart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/button_view_full_chart"
                        android:textColor="@color/primary_rose"
                        app:backgroundTint="@color/primary_rose_light"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_arrow_forward"
                        app:iconGravity="end"
                        app:iconTint="@color/primary_rose"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.Material3.Button.TextButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== VACCINE SUMMARY CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrowthSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_white"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_growth_summary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Weight change this month -->
                    <TextView
                        android:id="@+id/textWeightChangeMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:drawablePadding="8dp"
                        android:layout_marginTop="12dp" />

                    <!-- Height change since birth -->
                    <TextView
                        android:id="@+id/textHeightChangeBirth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:drawablePadding="8dp"
                        android:layout_marginTop="6dp" />

                    <!-- Weight change since birth -->
                    <TextView
                        android:id="@+id/textWeightChangeBirth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:drawablePadding="8dp"
                        android:layout_marginTop="6dp" />

                    <!-- Total records + last recorded -->
                    <TextView
                        android:id="@+id/textTotalRecords"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="10dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== UPCOMING VACCINES CARD (Phase 3) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUpcomingVaccines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_white"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_upcoming_vaccines"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:drawableStart="@drawable/ic_vaccine"
                            android:drawablePadding="8dp" />

                        <TextView
                            android:id="@+id/badgeOverdue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/vaccine_overdue"
                            android:background="@color/vaccine_overdue_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:visibility="gone"
                            tools:text="1 overdue" />
                    </RelativeLayout>

                    <!-- Container for upcoming vaccines list -->
                    <LinearLayout
                        android:id="@+id/layoutVaccineList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/textNoUpcomingVaccines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_no_upcoming"
                        android:textSize="14sp"
                        android:textColor="@color/vaccine_given"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                    <!-- View Full Schedule button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonViewSchedule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/button_view_schedule"
                        android:textColor="@color/primary_rose"
                        app:backgroundTint="@color/primary_rose_light"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_arrow_forward"
                        app:iconGravity="end"
                        app:iconTint="@color/primary_rose"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.Material3.Button.TextButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



            <!-- ===== ACTION BUTTONS ROW ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <!-- View History button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardViewHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/secondary_lavender_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_history"
                            android:contentDescription="@string/cd_history_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/button_view_history"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Vaccines button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVaccines"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/vaccine_upcoming_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_vaccine"
                            android:contentDescription="@string/cd_vaccine_icon"
                            app:tint="@color/vaccine_upcoming"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/button_vaccines"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Export CSV button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExportCsv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/tertiary_peach_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_export"
                            android:contentDescription="@string/cd_export_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/button_export_csv"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== FLOATING ACTION BUTTON ===== -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddMeasurement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/cd_add_measurement"
        app:backgroundTint="@color/fab_background"
        app:tint="@color/fab_icon"
        app:fabSize="normal"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
