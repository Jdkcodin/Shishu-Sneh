<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_onboarding.xml — The First Screen Users See

    Layout structure:
    ┌─────────────────────────────────────┐
    │         ❤️  (Heart Icon)            │
    │        Shishu Sneh                  │
    │    Your baby's companion...         │
    │                                     │
    │  ┌─────────────────────────────┐    │
    │  │  Baby Details               │    │
    │  │  ─────────────────────────  │    │
    │  │  👶 Baby's Name             │    │
    │  │  📅 Date of Birth           │    │
    │  │  👩 Mother's Name           │    │
    │  │  ⚧  Gender: ○Boy ○Girl ○…  │    │
    │  └─────────────────────────────┘    │
    │                                     │
    │  [ ✨ Start Journey  →  ]           │
    └─────────────────────────────────────┘

    Design choices:
    - ScrollView wraps everything (works on small screens)
    - MaterialCardView for the form (clean, elevated look)
    - TextInputLayout with OutlinedBox style (Material Design)
    - Large touch targets for mothers who aren't tech-savvy
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft_pink"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- ===== WELCOME SECTION ===== -->

        <!-- Heart icon — symbolizes love and care -->
        <ImageView
            android:id="@+id/imageWelcome"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_baby_welcome"
            android:contentDescription="@string/welcome_icon_desc" />

        <!-- App name -->
        <TextView
            android:id="@+id/textAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_rose"
            android:fontFamily="sans-serif-medium" />

        <!-- App tagline -->
        <TextView
            android:id="@+id/textTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_tagline"
            android:textSize="14sp"
            android:textColor="@color/secondary_lavender"
            android:fontFamily="sans-serif" />

        <!-- Welcome message -->
        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/onboarding_subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- ===== FORM CARD ===== -->

        <!--
            MaterialCardView = a card with rounded corners and shadow.
            All form inputs go inside this card for a clean, grouped look.
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Section header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/baby_details_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/baby_details_subtitle"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint" />

                <!-- ────── BABY'S NAME ────── -->
                <!--
                    TextInputLayout = Material text field wrapper
                    OutlinedBox = bordered style (clear boundaries)
                    startIconDrawable = icon on the left side
                -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutBabyName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="@string/hint_baby_name"
                    app:startIconDrawable="@drawable/ic_baby"
                    app:startIconTint="@color/primary_rose"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextBabyName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ────── DATE OF BIRTH ────── -->
                <!--
                    DOB field is NOT directly editable (focusable="false")
                    Clicking it opens a Material DatePicker dialog
                    This prevents keyboard issues and ensures valid dates
                -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/hint_dob"
                    app:startIconDrawable="@drawable/ic_calendar"
                    app:startIconTint="@color/primary_rose"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextDob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ────── MOTHER'S NAME ────── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutMotherName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/hint_mother_name"
                    app:startIconDrawable="@drawable/ic_mother"
                    app:startIconTint="@color/primary_rose"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextMotherName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ────── GENDER SELECTION ────── -->
                <!--
                    RadioGroup = only one option can be selected at a time
                    MaterialRadioButton = styled Material Design radio buttons
                    Gender is REQUIRED (as per user's specification)
                -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/label_gender"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <RadioGroup
                    android:id="@+id/radioGroupGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/gender_male"
                        android:buttonTint="@color/primary_rose"
                        android:textColor="@color/text_primary"
                        android:padding="4dp" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/gender_female"
                        android:buttonTint="@color/primary_rose"
                        android:textColor="@color/text_primary"
                        android:padding="4dp" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioOther"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/gender_other"
                        android:buttonTint="@color/primary_rose"
                        android:textColor="@color/text_primary"
                        android:padding="4dp" />

                </RadioGroup>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ===== START JOURNEY BUTTON ===== -->
        <!--
            MaterialButton = Material Design styled button
            cornerRadius="28dp" = fully rounded pill shape
            icon + iconGravity="end" = arrow icon on the right side
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStartJourney"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:text="@string/button_start_journey"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/primary_rose"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="end"
            app:iconTint="@android:color/white" />

    </LinearLayout>

</ScrollView>
